# worldweaver-agent environment
# Copy to .env in the project root and fill in your values.

# Required: LLM API key
WW_INFERENCE_KEY=

# WorldWeaver server
WW_SERVER_URL=http://localhost:8000/api

# LLM provider (OpenRouter is default)
WW_INFERENCE_URL=https://openrouter.ai/api/v1
WW_INFERENCE_MODEL=google/gemini-3-flash-preview

# Residents directory
WW_RESIDENTS_DIR=./residents

# Logging
WW_LOG_LEVEL=info

# Optional: override world ID (normally auto-detected from server)
# WW_WORLD_ID=world-20260309-161118-a5c6a773
